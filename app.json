{
  "expo": {
    "name": "Gym Buddy",
    "slug": "gym-buddy",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "gymbuddy",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "description": "Your AI-powered fitness companion — workouts, nutrition, habits & social",
    "privacy": "public",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0d0d0d"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.gymbuddy.app",
      "buildNumber": "1",
      "entitlements": {
        "com.apple.developer.healthkit": true,
        "com.apple.developer.healthkit.background-delivery": true
      },
      "infoPlist": {
        "NSHealthShareUsageDescription": "Gym Buddy reads your heart rate, sleep, HRV, and steps to give you recovery insights and live HR during workouts.",
        "NSHealthUpdateUsageDescription": "Gym Buddy writes workout data to Apple Health so your Exercise ring closes automatically.",
        "NSMotionUsageDescription": "Gym Buddy uses motion data to count your steps.",
        "NSCameraUsageDescription": "Gym Buddy uses the camera to scan food barcodes.",
        "NSSpeechRecognitionUsageDescription": "Gym Buddy may use speech recognition for voice logging."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0d0d0d"
      },
      "package": "com.gymbuddy.app",
      "minSdkVersion": 26,
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "versionCode": 1,
      "permissions": [
        "android.permission.ACTIVITY_RECOGNITION",
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO",
        "android.permission.health.READ_HEART_RATE",
        "android.permission.health.READ_SLEEP",
        "android.permission.health.READ_STEPS",
        "android.permission.health.READ_BASAL_METABOLIC_RATE",
        "android.permission.health.WRITE_EXERCISE",
        "android.permission.health.WRITE_HEART_RATE",
        "android.permission.health.READ_RESTING_HEART_RATE"
      ]
    },
    "plugins": [
      "expo-router",
      "expo-sqlite",
      [
        "expo-build-properties",
        {
          "android": {
            "minSdkVersion": 26
          }
        }
      ],
      [
        "expo-camera",
        {
          "cameraPermission": "Allow Gym Buddy to scan barcodes."
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/icon.png",
          "color": "#f97316"
        }
      ],
      "expo-secure-store"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "eas": {
        "projectId": "87ada62e-033b-4a11-807a-1440dfbf0638"
      },
      "router": {}
    },
    "owner": "saikrishnadas"
  }
}
