{
  "expo": {
    "name": "Gym Buddy",
    "slug": "gym-buddy",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "gymbuddy",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "description": "Your AI-powered fitness companion — workouts, nutrition, habits & social",
    "privacy": "public",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0d0d0d"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.gymbuddy.app",
      "buildNumber": "1",
      "infoPlist": {
        "NSHealthShareUsageDescription": "Gym Buddy reads your step count to show your daily activity.",
        "NSHealthUpdateUsageDescription": "Gym Buddy writes workout data to Apple Health.",
        "NSMotionUsageDescription": "Gym Buddy uses motion data to count your steps.",
        "NSCameraUsageDescription": "Gym Buddy uses the camera to scan food barcodes.",
        "NSSpeechRecognitionUsageDescription": "Gym Buddy may use speech recognition for voice logging."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0d0d0d"
      },
      "package": "com.gymbuddy.app",
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "versionCode": 1,
      "permissions": [
        "android.permission.ACTIVITY_RECOGNITION",
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO"
      ]
    },
    "plugins": [
      "expo-router",
      "expo-sqlite",
      [
        "expo-camera",
        {
          "cameraPermission": "Allow Gym Buddy to scan barcodes."
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/icon.png",
          "color": "#f97316"
        }
      ],
      "expo-secure-store"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "eas": {
        "projectId": "87ada62e-033b-4a11-807a-1440dfbf0638"
      },
      "router": {}
    },
    "owner": "saikrishnadas"
  }
}
